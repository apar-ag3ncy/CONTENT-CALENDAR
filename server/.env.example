# ── MongoDB Atlas connection ──────────────────────────────────────────────
# Atlas → your cluster → Connect → Drivers → copy the connection string.
# Replace <db_password> with your database user's password, and keep the
# database name (content_calendar) at the end of the path.
MONGODB_URI=mongodb+srv://<user>:<db_password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Database name to use inside the cluster.
DB_NAME=content_calendar

# Port the API listens on locally.
PORT=4000

# Public base URL of THIS api (used by the seed script to build photo URLs).
# Local: http://localhost:4000 . When deployed, set to your API's public URL.
PUBLIC_URL=http://localhost:4000
