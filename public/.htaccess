# SPA fallback for the content calendar (React Router uses real URLs).
# Vite copies everything in /public to the build root, so this lands in
# public_html/.htaccess on cPanel.
#
# Real files/folders (built assets, /api/, /media/) are served as-is; every
# other path falls through to index.html so client-side routes work on refresh.
#
# Deploying into a SUBFOLDER instead of the domain root? Change RewriteBase and
# the index.html target to match (e.g. /calendar/).

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Let real files and directories through untouched (this leaves /api/* and
  # /media/* — which are real folders — to their own handlers).
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else -> the SPA entry point.
  RewriteRule ^ index.html [L]
</IfModule>

# Long-cache fingerprinted build assets; never cache index.html.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|png|jpe?g|gif|svg|webp|avif|mp4)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
