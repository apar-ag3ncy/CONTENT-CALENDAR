# -----------------------------------------------------------------------------
# Frontend config. Copy this file to ".env.local" (local) or ".env.production"
# (build for deploy). Choose ONE of the two ways to point at the backend:
#
# 1) Same-origin (the cPanel PHP/MySQL setup — app + API on one domain).
#    Recommended: portable, no domain baked in. Calls go to relative /api/...
#        VITE_SAME_ORIGIN=1
#
# 2) Explicit origin (API on a different host). Set the ORIGIN only — the /api
#    path is built in. Requires CORS allowed on the API.
#        VITE_API_URL=https://your-api-host.com
#
# Leave BOTH unset to run in read-only demo mode (sample data only).
# See DEPLOY-CPANEL.md for the full cPanel deployment.
# -----------------------------------------------------------------------------

VITE_SAME_ORIGIN=1
# VITE_API_URL=
