# -----------------------------------------------------------------------------
# Frontend config. Copy this file to ".env.local".
#
# Point the app at the content-calendar API (the MongoDB backend in /server).
#   • Local dev:   http://localhost:4000
#   • Deployed:    your API's public URL (e.g. https://content-calendar-api.onrender.com)
#
# Leave it UNSET to run the app in read-only demo mode (sample data only).
# -----------------------------------------------------------------------------

VITE_API_URL=http://localhost:4000
